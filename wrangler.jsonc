{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "apps",
  "compatibility_date": "2025-09-27",
  "observability": {
    "enabled": true
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "main": "worker/src/index.js",
  "assets": {
    "directory": ".",
    "not_found_handling": "404-page",
    "binding": "ASSETS"
  }
}
